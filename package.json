{
  "name": "jm-comic",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "typecheck": "tsc --noEmit",
    "build": "pnpm typecheck && node --import tsx build/generate-manifest.ts && cross-env NODE_OPTIONS=\"--import tsx\" rspack build && node --import tsx build/generate-brotli.ts",
    "dev": "pnpm dev:serve",
    "dev:serve": "tsx dev-server.ts"
  },
  "dependencies": {
    "axios": "^1.13.0"
  },
  "devDependencies": {
    "@rspack/cli": "^1.5.7",
    "@rspack/core": "^1.5.7",
    "@types/node": "^24.6.0",
    "cross-env": "^10.1.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3"
  }
}
