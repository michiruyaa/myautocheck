{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "skipLibCheck": true,
    "types": [
      "node"
    ],
    "lib": [
      "ES2020",
      "DOM"
    ],
    "noEmit": true
  },
  "include": [
    "build/**/*.ts",
    "dev-server.ts",
    "rspack.config.ts",
    "rspack.shared.ts",
    "src/**/*.ts",
    "src/**/*.d.ts",
    "types/**/*.d.ts"
  ]
}